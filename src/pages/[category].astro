---
// Category Hub Pages — one page per occasion
// URLs: /wedding-guest-outfits/, /brunch-outfits/, etc.
// Each page targets a high-volume broad keyword and links to all related articles.
import Base from "../layouts/Base.astro";

const SITE = "https://askoutfit.com";

const CATEGORIES: Record<string, {
  slug: string;        // URL slug
  occasion: string;   // slug substring to match
  h1: string;
  title: string;
  metaDesc: string;
  intro: string;
  faq: { q: string; a: string }[];
}> = {
  "wedding-guest-outfits": {
    slug: "wedding-guest-outfits",
    occasion: "wedding-guest",
    h1: "Wedding Guest Outfits",
    title: "Wedding Guest Outfits — Complete Style Guide",
    metaDesc: "Find the perfect wedding guest outfit for any season, dress code, or venue. Complete guides for men and women — from black tie to beach weddings.",
    intro: "Finding the perfect wedding guest outfit shouldn't be stressful. Whether you're attending a black-tie ballroom reception, a relaxed garden party, or a beach ceremony, we've built a complete guide for every combination of season, dress code, and gender. Browse by season or style below — or use our AI stylist to get a personalised recommendation in seconds.",
    faq: [
      { q: "What should I wear as a wedding guest?", a: "The right outfit depends on the dress code, venue, and season. For black-tie weddings, choose a floor-length gown or tuxedo. For smart-casual weddings, tailored trousers with a blazer or a midi dress works beautifully. Always avoid white or ivory." },
      { q: "What colours should you avoid as a wedding guest?", a: "Avoid white, ivory, and cream — traditionally reserved for the bride. Very dark tones like all-black can also feel inappropriate at daytime or outdoor weddings. Opt for pastels, jewel tones, or warm neutrals." },
      { q: "Can you wear a jumpsuit to a wedding as a guest?", a: "Yes — a tailored jumpsuit in a luxe fabric like satin, crepe, or lace is a modern, elegant choice for cocktail or semi-formal weddings." },
    ],
  },
  "brunch-outfits": {
    slug: "brunch-outfits",
    occasion: "brunch",
    h1: "Brunch Outfits",
    title: "Brunch Outfits — Smart Casual Style Guides for Men & Women",
    metaDesc: "Discover the best brunch outfits for every season and style. Effortlessly chic looks for men and women — from relaxed weekend brunch to smart casual dining.",
    intro: "Brunch is the perfect excuse to dress up without overthinking it. The ideal brunch outfit strikes a balance between relaxed and polished — think linen, soft tailoring, and comfortable footwear. Whether you're heading to a rooftop terrace, a neighbourhood café, or a hotel Sunday brunch, our guides cover every season and style.",
    faq: [
      { q: "What is the best outfit for brunch?", a: "For brunch, smart-casual is the sweet spot. For women, a wrap dress, a linen set, or tailored wide-leg trousers with a silk blouse work beautifully. For men, chinos, a well-fitted shirt, and clean loafers or white trainers are a reliable choice." },
      { q: "Is there a dress code for brunch?", a: "Most brunches don't have a strict dress code — smart-casual is the safe standard. Avoid overly formal attire and overly casual looks like gym wear or flip-flops unless the venue specifically invites it." },
    ],
  },
  "beach-party-outfits": {
    slug: "beach-party-outfits",
    occasion: "beach-party",
    h1: "Beach Party Outfits",
    title: "Beach Party Outfits — Style Guides for Men & Women",
    metaDesc: "Find the perfect beach party outfit for any vibe. Relaxed, smart-casual, and elegant looks for men and women — for every season.",
    intro: "A beach party calls for outfits that look great, feel comfortable, and handle sand, sun, and sea breeze without missing a beat. Whether your beach event is a relaxed bonfire gathering or a more styled sunset cocktail party, the right outfit balances style with practicality.",
    faq: [
      { q: "What should I wear to a beach party?", a: "For a relaxed beach party, linen shirts, chino shorts, espadrilles, or breezy sundresses are ideal. For a smarter beach event, elevate with linen trousers, a structured blouse, or a maxi dress in a lightweight fabric." },
      { q: "What shoes should you wear to a beach party?", a: "Espadrilles, flat sandals, or woven leather shoes work best on sand. Avoid heels unless the event is on a terrace or hard surface." },
    ],
  },
  "first-date-outfits": {
    slug: "first-date-outfits",
    occasion: "first-date",
    h1: "First Date Outfit Ideas",
    title: "First Date Outfit Ideas for Men & Women",
    metaDesc: "Dress to impress on a first date. Smart-casual, formal, and relaxed outfit ideas for men and women — for every season and setting.",
    intro: "Your first date outfit should feel like the best version of you — not a costume. The goal is to look intentional and put-together without appearing overdressed for the venue. These guides cover every scenario: a casual coffee, a dinner date, a rooftop bar, or an outdoor day trip.",
    faq: [
      { q: "What should I wear on a first date?", a: "Match the venue. For a casual café date, smart-casual wins — chinos and a clean shirt for men, a wrap dress or jeans with a nice top for women. For a dinner date, elevate with a blazer or a midi dress. Always dress slightly above the venue's baseline." },
      { q: "Should you dress up for a first date?", a: "Yes — aim for slightly smarter than the venue requires. It signals effort and respect. But don't overcorrect: wearing a tuxedo to a pizza place is as awkward as wearing trainers to a fine-dining restaurant." },
    ],
  },
  "office-outfits": {
    slug: "office-outfits",
    occasion: "office",
    h1: "Office Outfit Ideas",
    title: "Office Outfit Ideas — Work Style Guides for Men & Women",
    metaDesc: "Master your office wardrobe. Smart-casual, formal, and relaxed work outfit ideas for men and women — for every season.",
    intro: "Your office outfit sets the tone before you speak a word. Whether your workplace is formal, smart-casual, or creative, the right work wardrobe combines professionalism with personal style. These guides cover seasonal updates and every dress code — so you'll always know what to wear.",
    faq: [
      { q: "What is appropriate office attire?", a: "Appropriate office attire depends on your industry and company culture. For corporate environments, tailored trousers, blazers, and dress shoes are standard. For creative or tech offices, smart-casual — clean jeans, a blazer, and leather trainers — is usually acceptable." },
      { q: "How do I dress smartly for the office without spending a lot?", a: "Focus on fit and neutral colours. Well-fitted navy trousers, a white shirt, and leather shoes in a dark colour form a versatile base that works across most office environments. Quality over quantity." },
    ],
  },
  "job-interview-outfits": {
    slug: "job-interview-outfits",
    occasion: "job-interview",
    h1: "Job Interview Outfit Ideas",
    title: "Job Interview Outfit Ideas — What to Wear to an Interview",
    metaDesc: "Dress to impress at your next job interview. Complete outfit guides for men and women covering every industry, season, and dress code.",
    intro: "Your interview outfit makes an impression before you've said a word. The right look conveys competence, attention to detail, and cultural fit. These guides cover every scenario — from a corporate finance interview to a creative agency, in every season.",
    faq: [
      { q: "What should I wear to a job interview?", a: "Research the company culture first. For corporate roles, a well-fitted suit in navy or grey is the safest choice. For startups or creative roles, smart-casual — clean chinos, a blazer, leather trainers — is often more appropriate. When in doubt, dress one level above the company's standard." },
      { q: "Should I wear a suit to every job interview?", a: "Not necessarily. A suit is appropriate for finance, law, or corporate roles. For tech, media, or creative industries, a blazer over smart trousers is often more fitting. Research the company's culture on LinkedIn or Glassdoor before deciding." },
    ],
  },
  "graduation-outfits": {
    slug: "graduation-outfits",
    occasion: "graduation",
    h1: "Graduation Outfit Ideas",
    title: "Graduation Outfit Ideas — What to Wear to Graduation",
    metaDesc: "Look your best on graduation day. Complete outfit guides for graduates and guests — men and women, every season.",
    intro: "Graduation day is one of the most photographed moments of your life. Your outfit should feel polished, celebrate the occasion, and stay comfortable through a long ceremony. Whether you're the graduate, a proud parent, or a guest, these guides have you covered.",
    faq: [
      { q: "What should I wear to my graduation?", a: "Under a graduation gown, you need a smart base layer — tailored trousers and a dress shirt for men, a midi dress or smart trousers and blouse for women. Choose shoes you can walk comfortably in. Avoid anything too casual." },
      { q: "What should parents wear to a graduation ceremony?", a: "Smart-casual to semi-formal is ideal. For mothers, a midi dress or tailored trousers with a blouse works well. For fathers, chinos with a blazer and dress shoes strikes the right note. Avoid casual wear like jeans and trainers." },
    ],
  },
  "concert-outfits": {
    slug: "concert-outfits",
    occasion: "concert",
    h1: "Concert Outfit Ideas",
    title: "Concert Outfit Ideas — What to Wear to a Concert",
    metaDesc: "Find the perfect concert outfit for any venue or artist. Style guides for men and women across every season and vibe.",
    intro: "Concert outfits should make you feel like yourself — just turned up to 10. Whether you're at an intimate jazz venue, an outdoor festival, or an arena show, the right look balances self-expression with practicality: comfortable footwear, weather-ready layers, and pieces that move with you.",
    faq: [
      { q: "What should I wear to a concert?", a: "Match the artist's vibe and the venue. For outdoor festivals, layer up with a denim jacket and comfortable boots. For arena shows, anything goes — this is your moment to express yourself. For classical concerts, smart-casual or semi-formal is appropriate." },
      { q: "What shoes should I wear to a concert?", a: "Comfort is key at concerts. You'll likely be standing for hours. Ankle boots, chunky trainers, or comfortable flat shoes work best. Save heels for seated venues." },
    ],
  },
};

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const cat = CATEGORIES[category as string];

// Load all English articles and filter by occasion
const modules = import.meta.glob("../content/articles/*.json", { eager: true });
const allArticles = Object.values(modules).map((m: any) => m.default ?? m);
const filtered = allArticles
  .filter((a: any) => a.lang === "en" && a.slug.includes(cat.occasion))
  .sort((a: any, b: any) => a.h1.localeCompare(b.h1));

const menArticles    = filtered.filter((a: any) => a.slug.includes("-men") || a.slug.includes("for-men"));
const womenArticles  = filtered.filter((a: any) => a.slug.includes("-women") || a.slug.includes("for-women"));
const otherArticles  = filtered.filter((a: any) => !menArticles.includes(a) && !womenArticles.includes(a));

const canonical = `${SITE}/${cat.slug}/`;
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: cat.faq.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Askoutfit", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: cat.h1, item: canonical },
  ],
};
---

<Base title={cat.title} description={cat.metaDesc} canonical={canonical}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">Askoutfit</a>
      <nav class="site-nav">
        <a href="/articles/" class="site-nav-link">All Guides</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <nav class="crumb"><a href="/">Askoutfit</a> › <span>{cat.h1}</span></nav>

    <h1>{cat.h1}</h1>
    <p class="intro">{cat.intro}</p>

    <div class="tool-cta">
      <h3>Not sure what to wear?</h3>
      <p>Describe your occasion and get a personalised outfit in seconds.</p>
      <a class="btn" href={`/?ref=${cat.slug}`}>Get My Outfit →</a>
    </div>

    {menArticles.length > 0 && (
      <section class="group">
        <h2>For Men</h2>
        <div class="art-grid">
          {menArticles.map((a: any) => (
            <a href={`/${a.slug}/`} class="art-card">
              <span class="art-title">{a.h1}</span>
              <span class="art-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {womenArticles.length > 0 && (
      <section class="group">
        <h2>For Women</h2>
        <div class="art-grid">
          {womenArticles.map((a: any) => (
            <a href={`/${a.slug}/`} class="art-card">
              <span class="art-title">{a.h1}</span>
              <span class="art-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {otherArticles.length > 0 && (
      <section class="group">
        <h2>More Guides</h2>
        <div class="art-grid">
          {otherArticles.map((a: any) => (
            <a href={`/${a.slug}/`} class="art-card">
              <span class="art-title">{a.h1}</span>
              <span class="art-arrow">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {cat.faq.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </section>
  </main>

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Askoutfit — <a href="/articles/">All Guides</a></p>
    <p class="aiom">A project by <a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
  </footer>
</Base>

<style>
  .site-header { position: sticky; top: 0; z-index: 20; border-bottom: 1px solid rgba(58,48,38,.6); background: rgba(26,20,16,.85); backdrop-filter: blur(12px); }
  .site-header-inner { max-width: 960px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; }
  .site-logo { font-family: "Playfair Display", Georgia, serif; font-size: 20px; font-weight: 600; text-decoration: none; color: var(--ink); }
  .site-nav-link { font-size: 14px; color: var(--muted); text-decoration: none; }
  .site-nav-link:hover { color: var(--ink); }

  .wrap { max-width: 960px; margin: 0 auto; padding: 36px 20px 80px; }
  .crumb { font-size: 13px; color: var(--faint); margin-bottom: 20px; }
  .crumb a { color: var(--gold); text-decoration: none; }
  h1 { font-family: "Playfair Display", Georgia, serif; font-weight: 600; font-size: clamp(30px, 5vw, 46px); margin: 0 0 16px; }
  .intro { color: var(--muted); font-size: 17px; line-height: 1.7; margin-bottom: 32px; }

  .tool-cta { margin: 0 0 40px; padding: 28px; border-radius: 18px; border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent); background: linear-gradient(135deg, color-mix(in srgb, var(--gold) 12%, var(--surface)), var(--surface)); text-align: center; }
  .tool-cta h3 { font-family: "Playfair Display", serif; font-size: 22px; margin-bottom: 8px; }
  .tool-cta p { color: var(--muted); margin: 0 0 16px; }
  .btn { display: inline-block; background: var(--gold); color: var(--bg); font-weight: 600; text-decoration: none; padding: 13px 26px; border-radius: 12px; transition: background .2s; }
  .btn:hover { background: #d8b67e; }

  .group { margin-bottom: 48px; }
  .group h2 { font-family: "Playfair Display", Georgia, serif; font-size: 26px; color: var(--gold); margin-bottom: 18px; }
  .art-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
  @media (min-width: 640px)  { .art-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .art-grid { grid-template-columns: repeat(3, 1fr); } }
  .art-card { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid var(--line); background: var(--surface); padding: 16px 18px; border-radius: 12px; text-decoration: none; transition: .2s; }
  .art-card:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); background: #271f17; }
  .art-title { font-size: 14px; font-weight: 500; line-height: 1.4; color: var(--gold); }
  .art-arrow { color: var(--gold); flex-shrink: 0; }

  .faq-section { margin-top: 50px; }
  .faq-section h2 { font-family: "Playfair Display", serif; font-size: 26px; margin-bottom: 18px; }
  .faq-item { border-bottom: 1px solid var(--line); padding: 16px 0; }
  .faq-item summary { cursor: pointer; font-weight: 600; list-style: none; font-size: 16px; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item p { color: var(--muted); margin-top: 10px; line-height: 1.7; }

  .site-footer { border-top: 1px solid rgba(58,48,38,.6); text-align: center; padding: 32px 20px; font-size: 12px; color: var(--faint); }
  .site-footer a { color: var(--gold); text-decoration: none; }
  .aiom { margin-top: 8px; }
  .aiom a { color: var(--gold); font-weight: 500; }
</style>
