---
import Base from "../layouts/Base.astro";

const modules = import.meta.glob("../content/articles/*.json", { eager: true });
const allArticles = Object.values(modules).map((m: any) => m.default ?? m);

export function getStaticPaths() {
  const mods = import.meta.glob("../content/articles/*.json", { eager: true });
  const all = Object.values(mods).map((m: any) => m.default ?? m);
  return all.map((a: any) => ({ params: { slug: a.slug }, props: { article: a, all } }));
}

const { article, all } = Astro.props as any;
const a = article;
const SITE = "https://askoutfit.com";
const canonical = `${SITE}/${a.slug}/`;
const altUrl = a.altSlug ? `${SITE}/${a.altSlug}/` : canonical;
const isAr = a.lang === "ar";

// ── Smart Related Articles ──────────────────────────────────────────────────
// Extract semantic dimensions from a slug to score similarity between articles.
const OCCASIONS = [
  "wedding-guest","beach-party","birthday-party","brunch","business-meeting",
  "casual-outing","concert","dinner-party","eid-celebration","engagement-party",
  "first-date","graduation","job-interview","office","travel-day",
];
const SEASONS  = ["summer","winter","spring","autumn"];
const STYLES   = ["smart-casual","formal","relaxed","elegant"];

function getOccasion(slug: string) { return OCCASIONS.find(o => slug.includes(o)) ?? ""; }
function getGender(slug: string)   { return slug.includes("-men") || slug.includes("for-men") ? "men" : slug.includes("-women") || slug.includes("for-women") ? "women" : ""; }
function getSeason(slug: string)   { return SEASONS.find(s => slug.startsWith(s + "-")) ?? ""; }
function getStyle(slug: string)    { return STYLES.find(s => slug.endsWith("-" + s) || slug.includes("-" + s + "-")) ?? ""; }

function similarity(slugA: string, slugB: string): number {
  let score = 0;
  const [oA, oB] = [getOccasion(slugA), getOccasion(slugB)];
  const [gA, gB] = [getGender(slugA),   getGender(slugB)];
  const [sA, sB] = [getSeason(slugA),   getSeason(slugB)];
  const [stA, stB] = [getStyle(slugA),  getStyle(slugB)];
  if (oA && oA === oB)   score += 5; // same occasion — strongest signal
  if (gA && gA === gB)   score += 3; // same gender
  if (sA && sA === sB)   score += 1; // same season
  if (stA && stA === stB) score += 1; // same style
  return score;
}

const related = (all as any[])
  .filter((x: any) => x.lang === a.lang && x.slug !== a.slug)
  .map((x: any) => ({ ...x, _score: similarity(a.slug, x.slug) }))
  .sort((x: any, y: any) => y._score - x._score || x.slug.localeCompare(y.slug))
  .slice(0, 3);

// ── Shop the Look — Amazon affiliate search links ───────────────────────────
const AMAZON_TAG = "askoutfit-20";
function amz(q: string) { return `https://www.amazon.com/s?k=${encodeURIComponent(q)}&tag=${AMAZON_TAG}`; }

const SHOP_MAP: Record<string, { men: string[]; women: string[] }> = {
  "wedding-guest":     { men: ["mens linen suit","mens dress shirt white","mens oxford shoes tan","mens pocket square"], women: ["women midi dress wedding guest","women heeled sandals wedding","women clutch bag evening","women fascinator hat"] },
  "beach-party":       { men: ["mens linen shirt casual","mens chino shorts","mens espadrilles","mens sunglasses polarized"], women: ["women beach party dress","women strappy sandals","women sun hat wide brim","women raffia bag"] },
  "brunch":            { men: ["mens smart casual chinos","mens polo shirt","mens white sneakers","mens lightweight blazer"], women: ["women wrap dress brunch","women block heel mules","women crossbody bag","women linen set"] },
  "birthday-party":    { men: ["mens party outfit smart casual","mens chelsea boots","mens slim trousers","mens printed shirt"], women: ["women satin dress party","women strappy heels","women statement earrings","women mini clutch"] },
  "business-meeting":  { men: ["mens suit business","mens dress shirt","mens tie silk","mens leather oxford shoes"], women: ["women blazer office","women tailored trousers","women silk blouse","women pointed toe pumps"] },
  "casual-outing":     { men: ["mens jeans slim fit","mens casual shirt","mens white leather sneakers","mens casual jacket"], women: ["women straight jeans","women casual blouse","women white trainers","women tote bag canvas"] },
  "concert":           { men: ["mens band tee","mens leather jacket","mens boots chelsea","mens dark jeans slim"], women: ["women concert outfit","women ankle boots","women oversized jacket","women crossbody bag leather"] },
  "dinner-party":      { men: ["mens chinos tailored","mens blazer navy","mens loafers leather","mens dress shirt no tie"], women: ["women evening dress midi","women kitten heels","women evening bag","women blazer feminine"] },
  "eid-celebration":   { men: ["mens thobe white","mens kandura","mens dress shoes formal","mens watch gold"], women: ["women abaya elegant","women jalabiya","women heels formal","women evening bag gold"] },
  "engagement-party":  { men: ["mens blazer light","mens chinos smart","mens loafers","mens pocket square floral"], women: ["women floral dress engagement","women wedge heels","women hair clip floral","women mini bag"] },
  "first-date":        { men: ["mens smart casual outfit","mens chinos navy","mens white shirt oxford","mens clean white sneakers"], women: ["women dress first date","women heeled boots","women small shoulder bag","women gold jewelry"] },
  "graduation":        { men: ["mens graduation suit","mens dress shirt","mens graduation shoes","mens graduation tie"], women: ["women graduation dress midi","women graduation heels","women graduation bag","women floral dress ceremony"] },
  "job-interview":     { men: ["mens interview suit navy","mens interview shirt white","mens leather shoes black","mens tie classic"], women: ["women interview blazer","women tailored dress","women court shoes","women structured handbag"] },
  "office":            { men: ["mens office trousers","mens office shirt","mens oxford shoes","mens leather belt"], women: ["women office dress","women office blazer","women court shoes heel","women tote bag office"] },
  "travel-day":        { men: ["mens travel outfit jogger","mens hoodie travel","mens trainers white","mens crossbody bag travel"], women: ["women travel outfit leggings","women oversized hoodie","women travel shoes","women travel backpack"] },
};

const occasion = getOccasion(a.slug);
const gender   = getGender(a.slug);
const shopItems: string[] = !isAr && occasion && (gender === "men" || gender === "women")
  ? (SHOP_MAP[occasion]?.[gender] ?? [])
  : [];

// ── Per-article OG image ────────────────────────────────────────────────────
const ogImage = `${SITE}/og/${a.slug}.svg`;

const faqHtml = (a.faq || [])
  .map((f: any) => `<details><summary>${f.q}</summary><p>${f.a}</p></details>`)
  .join("\n");

const articleSchema = {
  "@context": "https://schema.org", "@type": "Article",
  headline: a.title, description: a.metaDesc, image: `${SITE}/og-default.jpg`,
  datePublished: a.datePublished, dateModified: a.datePublished, inLanguage: a.lang,
  author: { "@type": "Organization", name: "Askoutfit" },
  publisher: { "@type": "Organization", name: "Askoutfit", logo: { "@type": "ImageObject", url: `${SITE}/logo.png` } },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};
const breadcrumbSchema = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Askoutfit", item: `${SITE}/` },
    { "@type": "ListItem", position: 2, name: isAr ? "المقالات" : "Articles", item: `${SITE}/articles/` },
    { "@type": "ListItem", position: 3, name: a.h1, item: canonical },
  ],
};
const faqSchema = {
  "@context": "https://schema.org", "@type": "FAQPage",
  mainEntity: (a.faq || []).map((f: any) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
};

const faqHeading = isAr ? "أسئلة شائعة" : "Frequently asked questions";
const altLabel = a.altLang === "ar" ? "العربية" : "English";
const articlesLabel = isAr ? "كل المقالات" : "All articles";
const relatedHeading = isAr ? "مقالات ذات صلة" : "Related articles";
---

<Base title={a.title} description={a.metaDesc} lang={a.lang} dir={a.dir}
  canonical={canonical} altLang={a.altLang} altUrl={altUrl} ogImage={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    {a.faq?.length > 0 && (<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />)}
  </Fragment>

  <!-- Unified header -->
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">Askoutfit</a>
      <nav class="site-nav">
        <a href={isAr ? "/articles-ar/" : "/articles/"} class="site-nav-link">{articlesLabel}</a>
        <a href={`/${a.altSlug || ""}/`} class="site-lang">{altLabel}</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <nav class="crumb" aria-label="breadcrumb">
      <a href="/">Askoutfit</a> &rsaquo; <a href={isAr ? "/articles-ar/" : "/articles/"}>{isAr ? "المقالات" : "Articles"}</a> &rsaquo; <span>{a.h1}</span>
    </nav>

    <article class="article">
      <h1>{a.h1}</h1>
      <div class="lead" set:html={a.introHtml} />

      <div class="tool-cta">
        <h3>{a.ctaTitle}</h3>
        <p>{a.ctaSub}</p>
        <a class="btn" href={isAr ? `/?lang=ar&ref=${a.slug}` : `/?ref=${a.slug}`} data-cta="top" data-slug={a.slug}>{a.ctaBtn}</a>
      </div>

      <div class="body" set:html={a.bodyHtml} />

      {shopItems.length > 0 && (
        <section class="shop-look">
          <h2 class="shop-heading">Shop the Look</h2>
          <p class="shop-sub">Tap any item to find it on Amazon — affiliate links help keep this site free.</p>
          <div class="shop-grid">
            {shopItems.map((item: string) => (
              <a href={amz(item)} target="_blank" rel="noopener nofollow sponsored" class="shop-card"
                 onclick={`if(typeof gtag==='function')gtag('event','shop_click',{item:'${item.replace(/'/g,"\\'")}',slug:'${a.slug}'})`}>
                <span class="shop-icon">🛍</span>
                <span class="shop-label">{item.replace(/\b\w/g, (c: string) => c.toUpperCase())}</span>
                <span class="shop-arrow">→</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="tool-cta">
        <h3>{a.ctaTitle}</h3>
        <p>{a.ctaSub}</p>
        <a class="btn" href={isAr ? `/?lang=ar&ref=${a.slug}` : `/?ref=${a.slug}`} data-cta="bottom" data-slug={a.slug}>{a.ctaBtn}</a>
      </div>

      <section class="faq">
        <h2>{faqHeading}</h2>
        <div set:html={faqHtml} />
      </section>

      {/* ── Email Capture ──────────────────────────────────────────────── */}
      {!isAr && (
        <section class="newsletter">
          <div class="nl-inner">
            <p class="nl-emoji">✉️</p>
            <h3 class="nl-title">Get weekly outfit ideas</h3>
            <p class="nl-sub">Fresh looks for every occasion, straight to your inbox. No spam — unsubscribe anytime.</p>
            <form class="nl-form" id="nl-form" action="https://formsubmit.co/mn.oun93@gmail.com" method="POST">
              <input type="hidden" name="_subject" value="New Askoutfit subscriber" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value="https://www.askoutfit.com/?subscribed=1" />
              <div class="nl-row">
                <input type="email" name="email" placeholder="your@email.com" required class="nl-email" />
                <button type="submit" class="nl-btn">Subscribe</button>
              </div>
            </form>
          </div>
        </section>
      )}

      {/* ── Social Share ───────────────────────────────────────────────── */}
      <div class="share-bar">
        <span class="share-label">{isAr ? "شارك:" : "Share:"}</span>
        <a id="pin-btn" class="share-btn share-pinterest" href="#" target="_blank" rel="noopener" aria-label="Save to Pinterest">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          Pinterest
        </a>
        <a id="wa-btn" class="share-btn share-whatsapp" href="#" target="_blank" rel="noopener" aria-label="Share on WhatsApp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <button id="copy-btn" class="share-btn share-copy" aria-label="Copy link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span id="copy-label">Copy link</span>
        </button>
      </div>

      {related.length > 0 && (
        <section class="related">
          <h2>{relatedHeading}</h2>
          <div class="related-grid">
            {related.map((r: any) => (
              <a href={`/${r.slug}/`} class="related-card">
                <span class="related-title">{r.h1}</span>
                <span class="related-arrow">{isAr ? "←" : "→"}</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </article>

    <footer>
      <p>&copy; {new Date().getFullYear()} Askoutfit.
        {isAr ? " قد نربح عمولة على عمليات الشراء عبر الروابط." : " We may earn a commission on purchases through links."}
      </p>
      <p><a href={isAr ? "/articles-ar/" : "/articles/"}>{articlesLabel}</a> &middot; <a href={`/${a.altSlug || ""}/`}>{altLabel}</a></p>
      <p class="aiom">{isAr ? "أحد مشاريع " : "A project by "}<a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
    </footer>
  </main>

  <script is:inline>
    document.querySelectorAll("[data-cta]").forEach((el) => {
      el.addEventListener("click", () => {
        if (typeof gtag === "function") {
          gtag("event", "cta_click", { location: el.getAttribute("data-cta"), slug: el.getAttribute("data-slug") });
        }
      });
    });

    // ── Social share ─────────────────────────────────────────────────────────
    const pageUrl  = encodeURIComponent(window.location.href);
    const pageTitle = encodeURIComponent(document.title);

    const pinBtn = document.getElementById("pin-btn");
    if (pinBtn) pinBtn.href = `https://pinterest.com/pin/create/button/?url=${pageUrl}&description=${pageTitle}`;

    const waBtn = document.getElementById("wa-btn");
    if (waBtn) waBtn.href = `https://wa.me/?text=${pageTitle}%20${pageUrl}`;

    const copyBtn = document.getElementById("copy-btn");
    const copyLabel = document.getElementById("copy-label");
    if (copyBtn) {
      copyBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          copyLabel.textContent = "Copied!";
          setTimeout(() => { copyLabel.textContent = "Copy link"; }, 2000);
        });
        if (typeof gtag === "function") gtag("event", "share", { method: "copy_link" });
      });
    }
  </script>
</Base>

<style>
  .site-header { position: sticky; top: 0; z-index: 20; border-bottom: 1px solid rgba(58,48,38,.6); background: rgba(26,20,16,.85); backdrop-filter: blur(12px); }
  .site-header-inner { max-width: 760px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; }
  .site-logo { font-family: "Playfair Display", Georgia, serif; font-size: 20px; font-weight: 600; text-decoration: none; color: var(--ink); }
  html[dir="rtl"] .site-logo { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .site-nav { display: flex; align-items: center; gap: 16px; }
  .site-nav-link { font-size: 14px; color: var(--muted); text-decoration: none; }
  .site-nav-link:hover { color: var(--ink); }
  .site-lang { display: inline-flex; align-items: center; border: 1px solid var(--line); color: var(--muted); font-size: 12px; padding: 6px 12px; border-radius: 999px; text-decoration: none; }
  .site-lang:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); color: var(--ink); }

  .wrap { max-width: 760px; margin: 0 auto; padding: 28px 20px 80px; }
  .crumb { font-size: 13px; color: var(--faint); margin-bottom: 28px; }
  .crumb a { text-decoration: none; color: var(--gold); }
  h1 { font-family: "Playfair Display", Georgia, serif; font-weight: 600; font-size: clamp(28px, 5vw, 42px); line-height: 1.2; margin-bottom: 18px; }
  html[dir="rtl"] h1 { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .lead :global(p) { font-size: 18px; color: var(--muted); margin-bottom: 8px; }
  .body :global(h2) { font-family: "Playfair Display", Georgia, serif; font-weight: 600; font-size: clamp(22px, 3.5vw, 28px); margin: 38px 0 14px; color: var(--gold); }
  html[dir="rtl"] .body :global(h2) { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .body :global(h3) { font-size: 19px; font-weight: 600; margin: 26px 0 10px; color: #e0c89a; }
  .body :global(p) { margin: 14px 0; }
  .body :global(ul), .body :global(ol) { margin: 14px 0; padding-inline-start: 22px; }
  .body :global(li) { margin: 8px 0; }
  .tool-cta { margin: 40px 0; padding: 28px; border-radius: 18px; border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent); background: linear-gradient(135deg, color-mix(in srgb, var(--gold) 12%, var(--surface)), var(--surface)); text-align: center; }
  .tool-cta h3 { font-family: "Playfair Display", serif; font-size: 22px; margin-bottom: 8px; }
  html[dir="rtl"] .tool-cta h3 { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .tool-cta p { color: var(--muted); margin: 0 0 16px; }
  .btn { display: inline-block; background: var(--gold); color: var(--bg); font-weight: 600; text-decoration: none; padding: 13px 26px; border-radius: 12px; transition: background 0.2s; }
  .btn:hover { background: #d8b67e; }
  .faq { margin-top: 40px; }
  .faq h2 { font-family: "Playfair Display", serif; font-size: 24px; margin-bottom: 8px; }
  html[dir="rtl"] .faq h2 { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .faq :global(details) { border-bottom: 1px solid var(--line); padding: 16px 0; }
  .faq :global(summary) { cursor: pointer; font-weight: 600; list-style: none; }
  .faq :global(summary)::-webkit-details-marker { display: none; }
  .faq :global(details p) { color: var(--muted); margin-top: 10px; }
  .related { margin-top: 50px; }
  .related h2 { font-family: "Playfair Display", serif; font-size: 24px; margin-bottom: 18px; }
  html[dir="rtl"] .related h2 { font-family: "Tajawal", sans-serif; font-weight: 700; }
  .related-grid { display: grid; gap: 12px; }
  .related-card { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid var(--line); background: var(--surface); padding: 16px 20px; border-radius: 12px; text-decoration: none; color: var(--ink); transition: .2s; }
  .related-card:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); background: #271f17; }
  .related-title { font-weight: 500; font-size: 15px; }
  .related-arrow { color: var(--gold); flex-shrink: 0; }
  .newsletter { margin: 44px 0; }
  .nl-inner { border: 1px solid color-mix(in srgb, var(--gold) 25%, transparent); border-radius: 18px; padding: 32px 28px; background: linear-gradient(135deg, color-mix(in srgb, var(--gold) 8%, var(--surface)), var(--surface)); text-align: center; }
  .nl-emoji { font-size: 28px; margin-bottom: 10px; }
  .nl-title { font-family: "Playfair Display", Georgia, serif; font-size: 22px; font-weight: 600; margin-bottom: 8px; }
  .nl-sub { color: var(--muted); font-size: 15px; margin-bottom: 20px; }
  .nl-row { display: flex; gap: 8px; max-width: 420px; margin: 0 auto; }
  .nl-email { flex: 1; background: var(--bg); border: 1px solid var(--line); border-radius: 10px; color: var(--ink); font-size: 15px; padding: 11px 14px; outline: none; transition: border-color .2s; }
