// ── getStaticPaths — articles + category hubs ────────────────────────────────
export function getStaticPaths() {
  const mods = import.meta.glob("../content/articles/*.json", { eager: true });
  const all = Object.values(mods).map((m: any) => m.default ?? m);

  const articlePaths = all.map((a: any) => ({
    params: { slug: a.slug },
    props: { article: a, all, category: null },
  }));

  const categoryPaths = Object.values({
    "wedding-guest-outfits":    "wedding-guest-outfits",
    "brunch-outfits":           "brunch-outfits",
    "beach-party-outfits":      "beach-party-outfits",
    "first-date-outfits":       "first-date-outfits",
    "office-outfits":           "office-outfits",
    "job-interview-outfits":    "job-interview-outfits",
    "graduation-outfits":       "graduation-outfits",
    "concert-outfits":          "concert-outfits",
    "birthday-party-outfits":   "birthday-party-outfits",
    "business-meeting-outfits": "business-meeting-outfits",
    "casual-outing-outfits":    "casual-outing-outfits",
    "dinner-party-outfits":     "dinner-party-outfits",
    "eid-celebration-outfits":  "eid-celebration-outfits",
    "engagement-party-outfits": "engagement-party-outfits",
    "travel-day-outfits":       "travel-day-outfits",
  }).map((catSlug) => ({
    params: { slug: catSlug as string },
    props: { article: null, all, category: catSlug },
  }));

  return [...articlePaths, ...categoryPaths];
}

// ── Per-page props ────────────────────────────────────────────────────────────
const { article, all, category: catSlugProp } = Astro.props as any;
const isHub = !!catSlugProp;
const cat   = isHub ? CATEGORIES[catSlugProp as string] : null;

// ── Article-only logic ────────────────────────────────────────────────────────
const a = article ?? {};

const OCCASIONS = [
  "wedding-guest","beach-party","birthday-party","brunch","business-meeting",
  "casual-outing","concert","dinner-party","eid-celebration","engagement-party",
  "first-date","graduation","job-interview","office","travel-day",
];
const SEASONS = ["summer","winter","spring","autumn"];
const STYLES  = ["smart-casual","formal","relaxed","elegant"];

function getOccasion(slug: string) { return OCCASIONS.find(o => slug.includes(o)) ?? ""; }
function getGender(slug: string) {
  return slug.includes("-men") || slug.includes("for-men") ? "men"
       : slug.includes("-women") || slug.includes("for-women") ? "women" : "";
}
function getSeason(slug: string) { return SEASONS.find(s => slug.startsWith(s + "-")) ?? ""; }
function getStyle(slug: string)  { return STYLES.find(s => slug.endsWith("-" + s) || slug.includes("-" + s + "-")) ?? ""; }

function similarity(slugA: string, slugB: string): number {
  let score = 0;
  const [oA, oB] = [getOccasion(slugA), getOccasion(slugB)];
  const [gA, gB] = [getGender(slugA),   getGender(slugB)];
  const [sA, sB] = [getSeason(slugA),   getSeason(slugB)];
  const [stA,stB]= [getStyle(slugA),    getStyle(slugB)];
  if (oA && oA === oB)   score += 5;
  if (gA && gA === gB)   score += 3;
  if (sA && sA === sB)   score += 1;
  if (stA && stA === stB) score += 1;
  return score;
}

const related = isHub ? [] : (all as any[])
  .filter((x: any) => x.lang === a.lang && x.slug !== a.slug)
  .map((x: any) => ({ ...x, _score: similarity(a.slug, x.slug) }))
  .sort((x: any, y: any) => y._score - x._score || x.slug.localeCompare(y.slug))
  .slice(0, 3);

