---
import Base from "../layouts/Base.astro";
import geoCitiesData from "../content/geo-cities.json";
import { GEO_SEASONS, SEASON_LABELS, GEO_CLIMATE_CONTENT } from "../lib/geo-content";

const modules = import.meta.glob("../content/articles/*.json", { eager: true });
const allArticles = Object.values(modules).map((m: any) => m.default ?? m);

const SITE = "https://askoutfit.com";

// ── Category Hub data ─────────────────────────────────────────────────────────
// Defined at module scope so getStaticPaths() and per-page code can both use it.
const CATEGORIES: Record<string, {
  slug: string; occasion: string; h1: string; title: string;
  metaDesc: string; intro: string; faq: { q: string; a: string }[];
}> = {
  "wedding-guest-outfits": {
