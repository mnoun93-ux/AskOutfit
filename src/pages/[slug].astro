};

// For Arabic articles, use altSlug (English) for occasion/gender lookup
const _lookupSlug = (!isHub && !isGeo) ? (a.lang === "ar" && a.altSlug ? a.altSlug : a.slug) : "";
const occasion  = (isHub || isGeo) ? "" : getOccasion(_lookupSlug);
const gender    = (isHub || isGeo) ? "" : getGender(_lookupSlug);
const shopItems: string[] = !isHub && !isGeo && occasion && (gender === "men" || gender === "women")
  ? (SHOP_MAP[occasion]?.[gender] ?? []) : [];

// ── Hero images — Pexels photo IDs (allows hotlinking) ───────────────────────
// URL: images.pexels.com/photos/{id}/pexels-photo-{id}.jpeg?auto=compress&cs=tinysrgb&w=760&h=400&fit=crop
const IMAGE_QUERIES: Record<string, { men: string; women: string }> = {
  "wedding-guest":    { men: "4259966",  women: "10408276" },
  "beach-party":      { men: "18465914", women: "14036399" },
  "brunch":           { men: "15994966", women: "10058448" },
  "birthday-party":   { men: "6621649",  women: "6405723"  },
  "business-meeting": { men: "32670017", women: "7433930"  },
  "casual-outing":    { men: "5488156",  women: "7165636"  },
  "concert":          { men: "2064805",  women: "6173891"  },
  "dinner-party":     { men: "9027058",  women: "5472918"  },
  "eid-celebration":  { men: "5416861",  women: "37593572" },
  "engagement-party": { men: "10112379", women: "32147266" },
  "first-date":       { men: "15994966", women: "4694566"  },
  "graduation":       { men: "32202904", women: "31290542" },
  "job-interview":    { men: "9077996",  women: "36733328" },
  "office":           { men: "31480550", women: "8122037"  },
  "travel-day":       { men: "7821325",  women: "7820739"  },
};

// ── Hub page article lists ────────────────────────────────────────────────────
const hubFiltered   = isHub ? allArticles.filter((x: any) => x.lang === "en" && x.slug.includes(cat!.occasion)).sort((x: any, y: any) => x.h1.localeCompare(y.h1)) : ([] as any[]);
const hubMen        = hubFiltered.filter((x: any) => x.slug.includes("-men") || x.slug.includes("for-men"));
const hubWomen      = hubFiltered.filter((x: any) => x.slug.includes("-women") || x.slug.includes("for-women"));
const hubOther      = hubFiltered.filter((x: any) => !hubMen.includes(x) && !hubWomen.includes(x));

// ── Shared computed ────────────────────────────────────────────────────────────
const canonical = isGeo ? `${SITE}/${geoSlug}/` : `${SITE}/${isHub ? cat!.slug : a.slug}/`;
const isAr      = !isHub && !isGeo && a.lang === "ar";
const altUrl    = !isHub && !isGeo && a.altSlug ? `${SITE}/${a.altSlug}/` : canonical;
const ogImage   = (isHub || isGeo) ? `${SITE}/og-default.jpg` : `${SITE}/og/${a.slug}.svg`;
const _heroId = !isHub && occasion && (gender === "men" || gender === "women")
  ? (IMAGE_QUERIES[occasion]?.[gender as "men" | "women"] ?? "")
  : "";
const heroImgSrc: string = _heroId
  ? `https://images.pexels.com/photos/${_heroId}/pexels-photo-${_heroId}.jpeg?auto=compress&cs=tinysrgb&w=760&h=400&fit=crop`
  : "";

// ── Hub Map for article → hub linking ────────────────────────────────────────
const HUB_MAP: Record<string, string> = {
  "wedding-guest":"wedding-guest-outfits","beach-party":"beach-party-outfits",
  "brunch":"brunch-outfits","birthday-party":"birthday-party-outfits",
  "business-meeting":"business-meeting-outfits","casual-outing":"casual-outing-outfits",
  "concert":"concert-outfits","dinner-party":"dinner-party-outfits",
  "eid-celebration":"eid-celebration-outfits","engagement-party":"engagement-party-outfits",
  "first-date":"first-date-outfits","graduation":"graduation-outfits",
  "job-interview":"job-interview-outfits","office":"office-outfits","travel-day":"travel-day-outfits",
};
const HUB_LABEL: Record<string, string> = {
  "wedding-guest":"Wedding Guest Outfits","beach-party":"Beach Party Outfits",
  "brunch":"Brunch Outfits","birthday-party":"Birthday Party Outfits",
  "business-meeting":"Business Meeting Outfits","casual-outing":"Casual Outing Outfits",
  "concert":"Concert Outfits","dinner-party":"Dinner Party Outfits",
  "eid-celebration":"Eid Celebration Outfits","engagement-party":"Engagement Party Outfits",
  "first-date":"First Date Outfits","graduation":"Graduation Outfits",
  "job-interview":"Job Interview Outfits","office":"Office Outfits","travel-day":"Travel Day Outfits",
};
const hubSlug  = !isHub && !isAr ? (HUB_MAP[occasion]  ?? "") : "";
const hubLabel = !isHub && !isAr ? (HUB_LABEL[occasion] ?? "") : "";

// ── Article schemas ───────────────────────────────────────────────────────────
const faqHtml = isHub ? "" : (a.faq || [])
  .map((f: any) => `<details><summary>${f.q}</summary><p>${f.a}</p></details>`)
  .join("\n");

const articleSchema = isHub ? null : {
  "@context": "https://schema.org", "@type": "Article",
  headline: a.title, description: a.metaDesc, image: ogImage,
  datePublished: a.datePublished, dateModified: a.datePublished, inLanguage: a.lang,
  author: { "@type": "Organization", name: "Askoutfit" },
  publisher: { "@type": "Organization", name: "Askoutfit", logo: { "@type": "ImageObject", url: `${SITE}/logo.png` } },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
};

const breadcrumbItems: any[] = isGeo
  ? [
      { "@type": "ListItem", position: 1, name: "Askoutfit", item: `${SITE}/` },
      { "@type": "ListItem", position: 2, name: "Travel Style Guides", item: `${SITE}/` },
      { "@type": "ListItem", position: 3, name: geoH1, item: canonical },
    ]
  : isHub
  ? [
      { "@type": "ListItem", position: 1, name: "Askoutfit", item: `${SITE}/` },
      { "@type": "ListItem", position: 2, name: cat!.h1, item: canonical },
    ]
  : (() => {
      const items: any[] = [
        { "@type": "ListItem", position: 1, name: "Askoutfit", item: `${SITE}/` },
        { "@type": "ListItem", position: 2, name: isAr ? "المقالات" : "Articles", item: isAr ? `${SITE}/articles-ar/` : `${SITE}/articles/` },
      ];
      if (!isAr && hubSlug) items.push({ "@type": "ListItem", position: 3, name: hubLabel, item: `${SITE}/${hubSlug}/` });
      items.push({ "@type": "ListItem", position: items.length + 1, name: a.h1, item: canonical });
      return items;
    })();

const breadcrumbSchema = { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: breadcrumbItems };

const faqSchema = isGeo
  ? { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: (geoContent?.faq ?? []).map((f: any) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) }
  : isHub
  ? { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: cat!.faq.map(f => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) }
  : (a.faq?.length > 0 ? { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: (a.faq || []).map((f: any) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })) } : null);

const shopSchema = shopItems.length > 0 ? {
  "@context": "https://schema.org", "@type": "ItemList",
  name: `Shop the Look — ${a.h1}`,
  itemListElement: shopItems.map((item: string, idx: number) => ({
    "@type": "ListItem", position: idx + 1, url: amz(item),
    name: item.replace(/\b\w/g, (c: string) => c.toUpperCase()),
  })),
} : null;

const faqHeading    = isAr ? "أسئلة شائعة" : "Frequently asked questions";
const altLabel      = !isHub && a.altLang === "ar" ? "العربية" : "English";
const articlesLabel = isAr ? "كل المقالات" : "All articles";
const relatedHeading = isAr ? "مقالات ذات صلة" : "Related articles";

const pageTitle = isGeo ? geoTitle : isHub ? cat!.title : a.title;
const pageDesc  = isGeo ? geoDesc  : isHub ? cat!.metaDesc : a.metaDesc;
---

<Base title={pageTitle} description={pageDesc}
  lang={isAr ? "ar" : "en"} dir={isAr ? "rtl" : "ltr"}
  canonical={canonical}
  altLang={!isHub ? a.altLang : undefined}
  altUrl={!isHub ? altUrl : undefined}
  ogImage={ogImage}>
  <Fragment slot="head">
    {articleSchema && (<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />)}
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && (<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />)}
    {shopSchema && (<script type="application/ld+json" is:inline set:html={JSON.stringify(shopSchema)} />)}
  </Fragment>

  {isGeo ? (
    /* ══════════════════ GEO pSEO PAGE TEMPLATE ══════════════════ */
    <>
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="site-logo">Askoutfit</a>
          <nav class="site-nav">
            <a href="/articles/" class="site-nav-link">All Guides</a>
          </nav>
        </div>
      </header>

      <main class="wrap">
        <nav class="crumb" aria-label="breadcrumb">
          <a href="/">Askoutfit</a> &rsaquo;
          <span>Travel Style Guides</span> &rsaquo;
          <span>{geoH1}</span>
        </nav>

        <article class="article">
          <h1>{geoH1}</h1>

          <div class="geo-meta">
            <span class="geo-badge">📍 {geoCity.name}, {geoCity.country}</span>
            <span class="geo-badge">🌡 {geoCity.temps[geoSeason as keyof typeof geoCity.temps]}</span>
          </div>

          <div class="lead">
            <p>{geoContent?.intro}</p>
          </div>

          <div class="tool-cta">
            <h3>Not sure what to wear?</h3>
            <p>Get a personalised outfit recommendation for {geoCity.name} in {geoSeasonLabel} — in seconds.</p>
            <a class="btn" href={`/?ref=${geoSlug}`}>Get My Outfit →</a>
          </div>

          <div class="body">
            <h2>What to Wear in {geoCity.name} in {geoSeasonLabel} — Key Tips</h2>
            <ul>
              {geoContent?.tips.map((tip: string) => <li>{tip}</li>)}
            </ul>

            {geoOccasionCards.length > 0 && (
              <>
                <h2>What to Wear by Occasion</h2>
                <p>Here's how to dress for the most common activities and settings you'll encounter in {geoCity.name} during {geoSeasonLabel}:</p>
                <div class="occasion-grid">
                  {geoOccasionCards.map((c: any) => (
                    <div class="occasion-card">
                      <div class="occasion-icon">{c.icon}</div>
                      <div class="occasion-body">
                        <h3 class="occasion-title">{c.title}</h3>
                        <p class="occasion-text">{c.outfit}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </>
            )}

            <h2>{geoSeasonLabel} Packing List for {geoCity.name}</h2>
            <p>These are the key pieces to include when packing for {geoCity.name} in {geoSeasonLabel}:</p>
            <ul class="packing-list">
              {geoContent?.packing.map((item: string) => <li>✓ {item}</li>)}
            </ul>

            <div class="shop-look">
              <h3 class="shop-heading">Shop the Look</h3>
              <p class="shop-sub">Find these key pieces on Amazon — affiliate links help keep this site free.</p>
              <div class="shop-grid">
                {geoContent?.packing.slice(0,6).map((item: string) => (
                  <a href={`https://www.amazon.com/s?k=${encodeURIComponent(item)}&tag=askoutfit-20`}
                     target="_blank" rel="noopener nofollow sponsored" class="shop-card">
                    <span class="shop-icon">🛍</span>
                    <span class="shop-label">{item}</span>
                    <span class="shop-arrow">→</span>
                  </a>
                ))}
              </div>
            </div>

            {geoCity.culturalNote && (
              <div class="cultural-note">
                <h3>🧭 Local Dress Culture & What to Know</h3>
                <p>{geoCity.culturalNote}</p>
              </div>
            )}

            {geoRelated.length > 0 && (
              <section class="geo-related">
                <h2>In-Depth Outfit Guides for {geoCity.name}</h2>
                <p class="geo-related-sub">Detailed style guides for every occasion you'll encounter on your trip:</p>
                <div class="related-grid">
                  {geoRelated.map((r: any) => (
                    <a href={`/${r.slug}/`} class="related-card">
                      <span class="related-title">{r.h1}</span>
                      <span class="related-arrow">→</span>
                    </a>
                  ))}
                </div>
              </section>
            )}

            {geoOtherSeasons.length > 0 && (
              <section class="geo-seasons">
                <h2>Planning a Different Season in {geoCity.name}?</h2>
                <p class="geo-related-sub">Explore our outfit guides for other times of year:</p>
                <div class="season-links">
                  {geoOtherSeasons.map((s: string) => (
                    <a href={`/what-to-wear-in-${geoCity.id}-${s}/`} class="season-link">
                      <span class="season-link-icon">
                        {s === "summer" ? "☀️" : s === "winter" ? "❄️" : s === "spring" ? "🌸" : "🍂"}
                      </span>
                      <span>What to Wear in {geoCity.name} in {SEASON_LABELS[s]}</span>
                      <span class="related-arrow">→</span>
                    </a>
                  ))}
                </div>
              </section>
            )}

            {geoSimilarCities.length > 0 && (
              <section class="geo-similar">
                <h2>Similar Climate Destinations</h2>
                <p class="geo-related-sub">These destinations share a similar climate to {geoCity.name} — your outfit strategy will transfer:</p>
                <div class="season-links">
                  {geoSimilarCities.map((c: any) => (
                    <a href={`/what-to-wear-in-${c.id}-${geoSeason}/`} class="season-link">
                      <span class="season-link-icon">📍</span>
                      <span>What to Wear in {c.name} in {geoSeasonLabel}</span>
                      <span class="related-arrow">→</span>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>

          <div class="tool-cta">
            <h3>Get a personalised recommendation</h3>
            <p>Describe your {geoCity.name} {geoSeasonLabel.toLowerCase()} plans and our AI stylist will suggest the perfect outfit.</p>
            <a class="btn" href={`/?ref=${geoSlug}`}>Try the AI Stylist →</a>
          </div>

          <section class="faq">
            <h2>Frequently Asked Questions</h2>
            {geoContent?.faq.map((f: any) => (
              <details class="faq-item">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))}
          </section>
        </article>

        <footer>
          <p>&copy; {new Date().getFullYear()} Askoutfit. We may earn a commission on purchases through links.</p>
          <p><a href="/articles/">All Guides</a></p>
          <p class="aiom">A project by <a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
        </footer>
      </main>
    </>
  ) : isHub ? (
    /* ══════════════════ HUB PAGE TEMPLATE ══════════════════ */
    <>
      <header class="site-header">
        <div class="site-header-inner hub-header-inner">
          <a href="/" class="site-logo">Askoutfit</a>
          <nav class="site-nav">
            <a href="/articles/" class="site-nav-link">All Guides</a>
          </nav>
        </div>
      </header>

      <main class="hub-wrap">
        <nav class="crumb"><a href="/">Askoutfit</a> › <span>{cat!.h1}</span></nav>

        <h1 class="hub-h1">{cat!.h1}</h1>
        <p class="hub-intro">{cat!.intro}</p>

        <div class="tool-cta">
          <h3>Not sure what to wear?</h3>
          <p>Describe your occasion and get a personalised outfit in seconds.</p>
          <a class="btn" href={`/?ref=${cat!.slug}`}>Get My Outfit →</a>
        </div>

        {hubMen.length > 0 && (
          <section class="group">
            <h2>For Men</h2>
            <div class="art-grid">
              {hubMen.map((x: any) => (
                <a href={`/${x.slug}/`} class="art-card">
                  <span class="art-title">{x.h1}</span>
                  <span class="art-arrow">→</span>
                </a>
              ))}
            </div>
          </section>
        )}

        {hubWomen.length > 0 && (
          <section class="group">
            <h2>For Women</h2>
            <div class="art-grid">
              {hubWomen.map((x: any) => (
                <a href={`/${x.slug}/`} class="art-card">
                  <span class="art-title">{x.h1}</span>
                  <span class="art-arrow">→</span>
                </a>
              ))}
            </div>
          </section>
        )}

        {hubOther.length > 0 && (
          <section class="group">
            <h2>More Guides</h2>
            <div class="art-grid">
              {hubOther.map((x: any) => (
                <a href={`/${x.slug}/`} class="art-card">
                  <span class="art-title">{x.h1}</span>
                  <span class="art-arrow">→</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="faq-section">
          <h2>Frequently Asked Questions</h2>
          {cat!.faq.map(f => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      </main>

      <footer class="site-footer-hub">
        <p>© {new Date().getFullYear()} Askoutfit — <a href="/articles/">All Guides</a></p>
        <p class="aiom">A project by <a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
      </footer>
    </>
  ) : (
    /* ══════════════════ ARTICLE PAGE TEMPLATE ══════════════════ */
    <>
      <header class="site-header">
        <div class="site-header-inner">
          <a href="/" class="site-logo">Askoutfit</a>
          <nav class="site-nav">
            <a href={isAr ? "/articles-ar/" : "/articles/"} class="site-nav-link">{articlesLabel}</a>
            <a href={`/${a.altSlug || ""}/`} class="site-lang">{altLabel}</a>
          </nav>
        </div>
      </header>

      <main class="wrap">
        <nav class="crumb" aria-label="breadcrumb">
          <a href="/">Askoutfit</a> &rsaquo;
          <a href={isAr ? "/articles-ar/" : "/articles/"}>{isAr ? "المقالات" : "Articles"}</a>
          {!isAr && hubSlug && (
            <Fragment>&nbsp;&rsaquo; <a href={`/${hubSlug}/`}>{hubLabel}</a></Fragment>
          )}
          &nbsp;&rsaquo; <span>{a.h1}</span>
        </nav>

        <article class="article">
          <h1>{a.h1}</h1>

          {heroImgSrc && (
            <div class="hero-img-wrap">
              <img
                src={heroImgSrc}
                alt={a.h1}
                width="760" height="400"
                loading="lazy"
                decoding="async"
                class="hero-img"
                onerror="this.closest('.hero-img-wrap').style.display='none'"
              />
            </div>
          )}

          <div class="lead" set:html={a.introHtml} />

          <div class="tool-cta">
            <h3>{a.ctaTitle}</h3>
            <p>{a.ctaSub}</p>
            <a class="btn" href={isAr ? `/?lang=ar&ref=${a.slug}` : `/?ref=${a.slug}`} data-cta="top" data-slug={a.slug}>{a.ctaBtn}</a>
          </div>

          <div class="body" set:html={a.bodyHtml} />

          {shopItems.length > 0 && (
            <section class="shop-look">
              <h2 class="shop-heading">{isAr ? "تسوق الإطلالة" : "Shop the Look"}</h2>
              <p class="shop-sub">{isAr ? "اضغط على أي قطعة لإيجادها على أمازون — روابط الأفيليت تساعد في إبقاء الموقع مجانياً." : "Tap any item to find it on Amazon — affiliate links help keep this site free."}</p>
              <div class="shop-grid">
                {shopItems.map((item: string) => (
                  <a href={amz(item)} target="_blank" rel="noopener nofollow sponsored" class="shop-card"
                     onclick={`if(typeof gtag==='function')gtag('event','shop_click',{item:'${item}',slug:'${a.slug}'})`}>
                    <span class="shop-icon">🛍</span>
                    <span class="shop-label">{item.replace(/\b\w/g, (c: string) => c.toUpperCase())}</span>
                    <span class="shop-arrow">→</span>
                  </a>
                ))}
              </div>
            </section>
          )}

          <div class="tool-cta">
            <h3>{a.ctaTitle}</h3>
            <p>{a.ctaSub}</p>
            <a class="btn" href={isAr ? `/?lang=ar&ref=${a.slug}` : `/?ref=${a.slug}`} data-cta="bottom" data-slug={a.slug}>{a.ctaBtn}</a>
          </div>

          <section class="faq">
            <h2>{faqHeading}</h2>
            <div set:html={faqHtml} />
          </section>

          <section class="newsletter">
              <div class="nl-inner">
                <p class="nl-emoji">✉️</p>
                <h3 class="nl-title">{isAr ? "أفكار أزياء أسبوعية" : "Get weekly outfit ideas"}</h3>
                <p class="nl-sub">{isAr ? "أحدث إطلالات لكل مناسبة، مباشرة إلى بريدك. بدون إزعاج — إلغاء الاشتراك في أي وقت." : "Fresh looks for every occasion, straight to your inbox. No spam — unsubscribe anytime."}</p>
                <form class="nl-form" action="https://formsubmit.co/mn.oun93@gmail.com" method="POST">
                  <input type="hidden" name="_subject" value="New Askoutfit subscriber" />
                  <input type="hidden" name="_captcha" value="false" />
                  <input type="hidden" name="_template" value="table" />
                  <input type="hidden" name="_next" value="https://www.askoutfit.com/?subscribed=1" />
                  <div class="nl-row">
                    <input type="email" name="email" placeholder={isAr ? "بريدك@الإلكتروني.com" : "your@email.com"} required class="nl-email" />
                    <button type="submit" class="nl-btn">{isAr ? "اشترك" : "Subscribe"}</button>
                  </div>
                </form>
              </div>
            </section>

          <div class="share-bar">
            <span class="share-label">{isAr ? "شارك:" : "Share:"}</span>
            <a id="pin-btn" class="share-btn share-pinterest" href="#" target="_blank" rel="noopener" aria-label="Save to Pinterest">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
              Pinterest
            </a>
            <a id="wa-btn" class="share-btn share-whatsapp" href="#" target="_blank" rel="noopener" aria-label="Share on WhatsApp">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <button id="copy-btn" class="share-btn share-copy" aria-label="Copy link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span id="copy-label">Copy link</span>
            </button>
          </div>

          {related.length > 0 && (
            <section class="related">
              <h2>{relatedHeading}</h2>
              <div class="related-grid">
                {related.map((r: any) => (
                  <a href={`/${r.slug}/`} class="related-card">
                    <span class="related-title">{r.h1}</span>
                    <span class="related-arrow">{isAr ? "←" : "→"}</span>
                  </a>
                ))}
              </div>
            </section>
          )}

          {!isAr && hubSlug && (
            <div class="hub-cta">
              <a href={`/${hubSlug}/`} class="hub-cta-link">
                Browse all {hubLabel} &rarr;
              </a>
            </div>
          )}
        </article>

        <footer>
          <p>&copy; {new Date().getFullYear()} Askoutfit.
            {isAr ? " قد نربح عمولة على عمليات الشراء عبر الروابط." : " We may earn a commission on purchases through links."}
          </p>
          <p><a href={isAr ? "/articles-ar/" : "/articles/"}>{articlesLabel}</a> &middot; <a href={`/${a.altSlug || ""}/`}>{altLabel}</a></p>
          <p class="aiom">{isAr ? "أحد مشاريع " : "A project by "}<a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
        </footer>
      </main>

      <script is:inline>
        document.querySelectorAll("[data-cta]").forEach((el) => {
          el.addEventListener("click", () => {
            if (typeof gtag === "function") {
              gtag("event", "cta_click", { location: el.getAttribute("data-cta"), slug: el.getAttribute("data-slug") });
            }
          });
        });
        const pageUrl   = encodeURIComponent(window.location.href);
        const pageTitle = encodeURIComponent(document.title);
        const pinBtn = document.getElementById("pin-btn");
        if (pinBtn) pinBtn.href = `https://pinterest.com/pin/create/button/?url=${pageUrl}&description=${pageTitle}`;
        const waBtn = document.getElementById("wa-btn");
        if (waBtn) waBtn.href = `https://wa.me/?text=${pageTitle}%20${pageUrl}`;
        const copyBtn   = document.getElementById("copy-btn");
        const copyLabel = document.getElementById("copy-label");
        if (copyBtn) {
          copyBtn.addEventListener("click", () => {
            navigator.clipboard.writeText(window.location.href).then(() => {
              copyLabel.textContent = "Copied!";
              setTimeout(() => { copyLabel.textContent = "Copy link"; }, 2000);
            });
            if (typeof gtag === "function") gtag("event", "share", { method: "copy_link" });
          });
        }
      </script>
    </>
  )}
</Base>

