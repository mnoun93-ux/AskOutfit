// ── getStaticPaths — articles + category hubs ────────────────────────────────
export function getStaticPaths() {
  const mods = import.meta.glob("../content/articles/*.json", { eager: true });
  const all = Object.values(mods).map((m: any) => m.default ?? m);

  const articlePaths = all.map((a: any) => ({
    params: { slug: a.slug },
    props: { article: a, all, category: null },
  }));

  const categoryPaths = Object.values({
    "wedding-guest-outfits":    "wedding-guest-outfits",
    "brunch-outfits":           "brunch-outfits",
    "beach-party-outfits":      "beach-party-outfits",
    "first-date-outfits":       "first-date-outfits",
    "office-outfits":           "office-outfits",
    "job-interview-outfits":    "job-interview-outfits",
    "graduation-outfits":       "graduation-outfits",
    "concert-outfits":          "concert-outfits",
    "birthday-party-outfits":   "birthday-party-outfits",
    "business-meeting-outfits": "business-meeting-outfits",
    "casual-outing-outfits":    "casual-outing-outfits",
    "dinner-party-outfits":     "dinner-party-outfits",
    "eid-celebration-outfits":  "eid-celebration-outfits",
    "engagement-party-outfits": "engagement-party-outfits",
    "travel-day-outfits":       "travel-day-outfits",
  }).map((catSlug) => ({
    params: { slug: catSlug as string },
    props: { article: null, all, category: catSlug },
  }));

  const geoCities: any[] = geoCitiesData as any[];
  const geoPaths = geoCities.flatMap((city: any) =>
    (GEO_SEASONS as readonly string[]).map((season: string) => ({
      params: { slug: `what-to-wear-in-${city.id}-${season}` },
      props: { article: null, all, category: null, geoCity: city, geoSeason: season },
    }))
  );

  return [...articlePaths, ...categoryPaths, ...geoPaths];
}

// ── Per-page props ────────────────────────────────────────────────────────────
const { article, all, category: catSlugProp, geoCity, geoSeason } = Astro.props as any;
const isGeo = !!geoCity;
const isHub = !isGeo && !!catSlugProp;
const cat   = isHub ? CATEGORIES[catSlugProp as string] : null;

// ── Geo-page logic ────────────────────────────────────────────────────────────
const geoContent = isGeo
  ? (GEO_CLIMATE_CONTENT[geoCity.climate]?.[geoSeason] ?? GEO_CLIMATE_CONTENT.temperate[geoSeason])
  : null;
const geoSeasonLabel = isGeo ? (SEASON_LABELS[geoSeason] ?? geoSeason) : "";
const geoSlug = isGeo ? `what-to-wear-in-${geoCity.id}-${geoSeason}` : "";
const geoTitle = isGeo ? `What to Wear in ${geoCity.name} in ${geoSeasonLabel} — Packing & Outfit Guide` : "";
const geoDesc  = isGeo ? `What to wear in ${geoCity.name} in ${geoSeasonLabel}: climate-specific outfit tips, a full packing list, local dress culture, and occasion-by-occasion advice for ${geoCity.country}.` : "";
const geoH1    = isGeo ? `What to Wear in ${geoCity.name} in ${geoSeasonLabel}` : "";

// Related articles — deterministic sort (by slug), show up to 8
const geoRelated = isGeo
  ? (allArticles as any[])
      .filter((x: any) => x.lang === "en" && geoContent?.occasions.some((o: string) => x.slug.includes(o)))
      .sort((a: any, b: any) => a.slug.localeCompare(b.slug))
      .slice(0, 8)
  : [];

// Other seasons for this city (internal links)
const geoOtherSeasons = isGeo
  ? (GEO_SEASONS as readonly string[]).filter((s: string) => s !== geoSeason)
  : [];

// Similar climate cities (internal links)
const geoSimilarCities = isGeo
  ? (geoCitiesData as any[])
      .filter((c: any) => c.climate === geoCity.climate && c.id !== geoCity.id)
      .slice(0, 5)
  : [];

// Occasion outfit cards — climate × season specific advice
const GEO_OCCASION_OUTFITS: Record<string, Record<string, Array<{icon:string; title:string; outfit:string}>>> = {
  hot_dry: {
    summer: [
      { icon:"🗺", title:"Sightseeing & Outdoor Exploring", outfit:`Loose linen trousers with a lightweight linen shirt or kaftan in a pale colour. Wide-brim hat, quality sunglasses, and a lightweight scarf you can drape for shade. Comfortable flat sandals — pavements will be extremely hot.` },
      { icon:"🍽", title:"Evening Dining & Nightlife", outfit:`The evenings cool slightly, making them the social highlight of the day. A flowy midi dress or smart linen trousers with a silk or satin blouse are ideal. Add a light wrap in case air conditioning is strong indoors.` },
      { icon:"🏊", title:"Beach, Pool & Resort", outfit:`Swimwear is perfectly appropriate at beaches and hotel pools. A kaftan or linen cover-up for moving between pool and restaurant. Smart sandals that work from poolside to a casual lunch. Cover up modestly when leaving resort grounds.` },
      { icon:"💼", title:"Business Meetings & Offices", outfit:`Offices are heavily air-conditioned — bring a blazer or structured jacket even in summer. Lightweight tailored trousers, a pressed shirt or smart blouse, and closed smart shoes. The contrast between outdoor heat and indoor cold is significant.` },
    ],
    winter: [
      { icon:"🗺", title:"Sightseeing & Outdoor Exploring", outfit:`Comfortable smart-casual clothing — chinos or light jeans, a collared shirt or blouse, and comfortable walking shoes. A light jacket or blazer for the evenings. This is the best season to explore outdoor attractions.` },
      { icon:"🍽", title:"Evening Dining & Restaurants", outfit:`Smart casual is the standard for evening dining in Gulf cities. Chinos and a blazer for men, a midi dress or elegant trousers with a blouse for women. Add a light wrap or jacket as indoor air conditioning is common year-round.` },
      { icon:"🛍", title:"Shopping Malls & Indoor Venues", outfit:`Malls are heavily air-conditioned — a light jacket or cardigan is essential. Smart casual dress that's appropriate for both the comfortable outdoor temperatures and the colder indoor environment.` },
      { icon:"💼", title:"Business & Formal Events", outfit:`Business formal remains appropriate year-round. A well-fitted suit or smart dress with a blazer, quality shoes, and conservative accessories. The comfortable winter temperatures make this an easier season for formal dressing.` },
    ],
    spring: [
      { icon:"🗺", title:"Sightseeing & Day Trips", outfit:`Light, breathable layers — linen trousers or a cotton dress with a long-sleeved layer you can remove as the day heats up. A hat and sunglasses are increasingly important as spring progresses. Comfortable walking shoes or sandals.` },
      { icon:"🍽", title:"Evening Dining & Socialising", outfit:`Early spring evenings are particularly pleasant for outdoor dining. Smart casual — a light dress or chinos with a neat shirt — is the perfect balance. You may not need a jacket in early spring, but have one available by May.` },
      { icon:"🌅", title:"Outdoor Events & Activities", outfit:`Lightweight, practical clothing in breathable fabrics. Sun protection is key — a long-sleeved linen shirt is both stylish and protective. Comfortable footwear for uneven surfaces like souqs and heritage sites.` },
      { icon:"💼", title:"Business & Professional", outfit:`Lightweight suits or tailored separates work well in the mild spring temperatures. A blazer or jacket for air-conditioned environments. Quality, conservative dress that is both comfortable in the warming weather and professionally appropriate.` },
    ],
    fall: [
      { icon:"🗺", title:"Sightseeing & Exploring", outfit:`Early autumn calls for full summer clothing — linen, breathable fabrics, hat and sunglasses. By November, you can layer slightly with a light long-sleeved shirt or a light jacket for evening sightseeing.` },
      { icon:"🍽", title:"Evening Dining & Outdoor Events", outfit:`Autumn marks the return of outdoor dining and events. Smart casual for evenings — a light dress or tailored pieces that work indoors and in the increasingly pleasant evening air. A light wrap or jacket for later in the season.` },
      { icon:"🛍", title:"Shopping & Indoor Activities", outfit:`The indoor-outdoor temperature contrast eases slightly in autumn. Smart casual still works — light trousers or a skirt with a blouse and a light layer for air-conditioned spaces.` },
      { icon:"💼", title:"Business & Professional", outfit:`Comfortable business attire — the cooling temperatures make autumn a slightly easier season for formal wear. Lightweight suits in breathable fabrics, smart shoes, and conservative accessories are appropriate for most professional contexts.` },
    ],
  },
  hot_humid: {
    summer: [
      { icon:"🗺", title:"Sightseeing & Outdoor Exploring", outfit:`Moisture-wicking, loose-fitting clothing in light colours is non-negotiable. A breathable performance fabric shirt, light quick-dry trousers, and comfortable shoes that can handle sudden rain. Carry a compact packable rain jacket.` },
      { icon:"🍽", title:"Evening Dining", outfit:`A change of clothes for the evening is highly recommended after a day of sightseeing. A light dress or fresh smart-casual separates — the evening temperatures are still warm but more comfortable than midday.` },
      { icon:"🏖", title:"Beach & Waterfront", outfit:`Lightweight beach-to-bar resort wear — a cover-up over swimwear for the beach, transitioning to a casual dress or shorts and shirt for waterfront dining. Quick-dry fabrics are essential near the water.` },
      { icon:"💼", title:"Business Meetings", outfit:`Always carry a blazer — offices are aggressively air-conditioned. A light, crisp shirt or blouse (that doesn't show sweat easily) with lightweight tailored trousers. Change into the blazer before entering the meeting.` },
    ],
    winter: [
