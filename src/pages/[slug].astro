// ── Article-only logic ────────────────────────────────────────────────────────
const a = article ?? {};

const OCCASIONS = [
  "wedding-guest","beach-party","birthday-party","brunch","business-meeting",
  "casual-outing","concert","dinner-party","eid-celebration","engagement-party",
  "first-date","graduation","job-interview","office","travel-day",
];
const SEASONS = ["summer","winter","spring","autumn"];
const STYLES  = ["smart-casual","formal","relaxed","elegant"];

function getOccasion(slug: string) { return OCCASIONS.find(o => slug.includes(o)) ?? ""; }
function getGender(slug: string) {
  return slug.includes("-men") || slug.includes("for-men") ? "men"
       : slug.includes("-women") || slug.includes("for-women") ? "women" : "";
}
function getSeason(slug: string) { return SEASONS.find(s => slug.startsWith(s + "-")) ?? ""; }
function getStyle(slug: string)  { return STYLES.find(s => slug.endsWith("-" + s) || slug.includes("-" + s + "-")) ?? ""; }

function similarity(slugA: string, slugB: string): number {
  let score = 0;
  const [oA, oB] = [getOccasion(slugA), getOccasion(slugB)];
  const [gA, gB] = [getGender(slugA),   getGender(slugB)];
  const [sA, sB] = [getSeason(slugA),   getSeason(slugB)];
  const [stA,stB]= [getStyle(slugA),    getStyle(slugB)];
  if (oA && oA === oB)   score += 5;
  if (gA && gA === gB)   score += 3;
  if (sA && sA === sB)   score += 1;
  if (stA && stA === stB) score += 1;
  return score;
}

const related = (isHub || isGeo) ? [] : (all as any[])
  .filter((x: any) => x.lang === a.lang && x.slug !== a.slug)
  .map((x: any) => ({ ...x, _score: similarity(a.slug, x.slug) }))
  .sort((x: any, y: any) => y._score - x._score || x.slug.localeCompare(y.slug))
  .slice(0, 3);

