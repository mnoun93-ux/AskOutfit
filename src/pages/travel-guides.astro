---
import Base from "../layouts/Base.astro";
import geoCitiesData from "../content/geo-cities.json";

const SITE = "https://askoutfit.com";

const SEASONS = [
  { id: "summer", label: "Summer",  icon: "☀️" },
  { id: "winter", label: "Winter",  icon: "❄️" },
  { id: "spring", label: "Spring",  icon: "🌸" },
  { id: "fall",   label: "Autumn",  icon: "🍂" },
] as const;

const REGION_LABELS: Record<string, string> = {
  middle_east:   "Middle East & North Africa",
  europe:        "Europe",
  north_america: "North America",
  asia_pacific:  "Asia-Pacific",
  africa:        "Africa",
  latin_america: "Latin America",
};

const REGION_LABELS_AR: Record<string, string> = {
  middle_east:   "الشرق الأوسط وشمال أفريقيا",
  europe:        "أوروبا",
  north_america: "أمريكا الشمالية",
  asia_pacific:  "آسيا والمحيط الهادئ",
  africa:        "أفريقيا",
  latin_america: "أمريكا اللاتينية",
};

const SEASONS_AR: Record<string, string> = {
  summer: "صيف", winter: "شتاء", spring: "ربيع", fall: "خريف",
};

const REGION_ORDER = ["middle_east","europe","north_america","asia_pacific","africa","latin_america"];

const cities: any[] = geoCitiesData as any[];

// Group cities by region, preserve REGION_ORDER
const byRegion: Record<string, any[]> = {};
REGION_ORDER.forEach(r => { byRegion[r] = []; });
cities.forEach(c => { (byRegion[c.region] ??= []).push(c); });

const totalPages = cities.length * SEASONS.length;
---

<Base
  title="Destination Style Guides — What to Wear Around the World"
  description={`Climate-specific outfit guides for ${cities.length} cities around the world. Find out exactly what to wear in every season — from Dubai summer to London winter.`}
  canonical={`${SITE}/travel-guides/`}
>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">Askoutfit</a>
      <nav class="site-nav">
        <a href="/articles/" class="site-nav-link" data-en="Outfit Guides" data-ar="المقالات">Outfit Guides</a>
        <a href="/travel-guides/" class="site-nav-link active" data-en="Travel" data-ar="أدلة السفر">Travel</a>
        <button id="lang-toggle" class="site-lang" data-en="العربية" data-ar="English">العربية</button>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <div class="hero">
      <p class="hero-tag" data-en="✈️ Travel Style" data-ar="✈️ أدلة أزياء السفر">✈️ Travel Style</p>
      <h1 data-en="What to Wear Around the World" data-ar="ماذا تلبس حول العالم">What to Wear Around the World</h1>
      <p class="hero-sub" data-en={`Climate-specific outfit guides for ${cities.length} cities — covering every season. ${totalPages} guides total.`} data-ar={`أدلة أزياء حسب المناخ لـ ${cities.length} مدينة — لكل فصل من فصول السنة. ${totalPages} دليل.`}>
        Climate-specific outfit guides for {cities.length} cities — covering every season.
        {totalPages} guides total.
      </p>
      <div class="search-box">
        <input id="city-search" type="search" placeholder="Search a city… e.g. Tokyo, Dubai, Paris" data-en-placeholder="Search a city… e.g. Tokyo, Dubai, Paris" data-ar-placeholder="ابحث عن مدينة... مثل: دبي، لندن، باريس" autocomplete="off" />
      </div>
    </div>

    <div id="no-results" class="no-results" style="display:none">No cities found. Try another name.</div>

    {REGION_ORDER.filter(r => byRegion[r]?.length > 0).map(regionId => (
      <section class="region-section">
        <h2 class="region-title" data-en={REGION_LABELS[regionId]} data-ar={REGION_LABELS_AR[regionId]}>{REGION_LABELS[regionId]}</h2>
        <div class="city-grid">
          {byRegion[regionId].map((city: any) => (
            <div class="city-card" data-city={`${city.name} ${city.country}`.toLowerCase()}>
              <div class="city-header">
                <div>
                  <p class="city-name">{city.name}</p>
                  <p class="city-country">{city.country}</p>
                </div>
              </div>
              <div class="season-row">
                {SEASONS.map(s => (
                  <a href={`/what-to-wear-in-${city.id}-${s.id}/`} class="season-btn" data-en={s.label} data-ar={SEASONS_AR[s.id]} data-en-href={`/what-to-wear-in-${city.id}-${s.id}/`} data-ar-href={`/ar/what-to-wear-in-${city.id}-${s.id}/`}>
                    <span>{s.icon}</span>
                    <span class="season-label">{s.label}</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <div class="tool-cta">
      <h3 data-en="Not sure what to wear on your trip?" data-ar="لا تعرف ماذا تلبس في رحلتك؟">Not sure what to wear on your trip?</h3>
      <p data-en="Describe your destination, occasion, and plans — our AI stylist will suggest a complete outfit in seconds." data-ar="صف وجهتك ومناسبتك وخططك — سيقترح مصممنا الذكي إطلالة كاملة في ثوانٍ.">Describe your destination, occasion, and plans — our AI stylist will suggest a complete outfit in seconds.</p>
      <a class="btn" href="/?ref=travel-guides" data-en="Get My Outfit →" data-ar="احصل على إطلالتي ←">Get My Outfit →</a>
    </div>
  </main>

  <footer class="site-footer">
    <p class="site-footer-logo">Askoutfit</p>
    <p>We may earn a commission on purchases through links. © <span id="y"></span></p>
    <p class="aiom">A project by <a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
  </footer>

  <script is:inline>
    document.getElementById("y").textContent = new Date().getFullYear();

    // ── Bilingual toggle ──────────────────────────────────────────────────────
    const isAr = new URLSearchParams(window.location.search).get("lang") === "ar";

    function applyLang(ar) {
      document.documentElement.lang = ar ? "ar" : "en";
      document.documentElement.dir  = ar ? "rtl" : "ltr";

      // Swap text for simple elements (no child elements) — exclude .season-btn (has inner spans)
      document.querySelectorAll("[data-en]:not(.season-btn)").forEach(el => {
        const key = ar ? el.dataset.ar : el.dataset.en;
        if (!key) return;
        el.textContent = key;
      });

      // Swap season labels + hrefs — keep emoji span intact
      document.querySelectorAll(".season-btn").forEach(btn => {
        const lbl = btn.querySelector(".season-label");
        if (lbl) lbl.textContent = ar ? (btn.dataset.ar || lbl.textContent) : (btn.dataset.en || lbl.textContent);
        const href = ar ? btn.dataset.arHref : btn.dataset.enHref;
        if (href) btn.setAttribute("href", href);
      });

      // Swap search placeholder
      const inp = document.getElementById("city-search");
      if (inp) inp.placeholder = ar ? inp.dataset.arPlaceholder : inp.dataset.enPlaceholder;

      // Update lang toggle button
      const btn = document.getElementById("lang-toggle");
      if (btn) btn.textContent = ar ? "English" : "العربية";

      // Update nav links href for lang
      document.querySelector('a[href="/articles/"]')?.setAttribute("href", ar ? "/articles-ar/" : "/articles/");
    }

    if (isAr) applyLang(true);

    document.getElementById("lang-toggle")?.addEventListener("click", () => {
      const nowAr = document.documentElement.lang !== "ar";
      const url = new URL(window.location.href);
      if (nowAr) url.searchParams.set("lang", "ar");
      else url.searchParams.delete("lang");
      window.history.replaceState({}, "", url);
      applyLang(nowAr);
    });

    // ── City search ───────────────────────────────────────────────────────────
    const input = document.getElementById("city-search");
    const noResults = document.getElementById("no-results");
    const cards = document.querySelectorAll(".city-card");
    const sections = document.querySelectorAll(".region-section");

    input.addEventListener("input", () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach(card => {
        const match = !q || card.dataset.city.includes(q);
        card.style.display = match ? "" : "none";
        if (match) visible++;
      });
      sections.forEach(sec => {
        const anyVisible = [...sec.querySelectorAll(".city-card")].some(c => c.style.display !== "none");
        sec.style.display = anyVisible ? "" : "none";
      });
      noResults.style.display = (q && visible === 0) ? "" : "none";
    });
  </script>
</Base>

<style>
  /* ── Header ───────────────────────────────────────────────────────────────── */
  .site-header { position: sticky; top: 0; z-index: 20; border-bottom: 1px solid rgba(58,48,38,.6); background: rgba(26,20,16,.85); backdrop-filter: blur(12px); }
  .site-header-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; }
  .site-logo { font-family: "Playfair Display", Georgia, serif; font-size: 20px; font-weight: 600; text-decoration: none; color: var(--ink); }
  .site-nav { display: flex; align-items: center; gap: 20px; }
  .site-nav-link { font-size: 14px; color: var(--muted); text-decoration: none; transition: color .15s; }
  .site-nav-link:hover, .site-nav-link.active { color: var(--gold); }
  #lang-toggle { background: none; border: 1px solid var(--line); color: var(--muted); font-size: 13px; padding: 5px 12px; border-radius: 999px; cursor: pointer; font-family: inherit; transition: .15s; }
  #lang-toggle:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); color: var(--gold); }

  /* ── Layout ───────────────────────────────────────────────────────────────── */
  .wrap { max-width: 1100px; margin: 0 auto; padding: 40px 20px 80px; }

  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .hero { text-align: center; padding: 40px 0 52px; }
  .hero-tag { font-size: 13px; color: var(--gold); letter-spacing: .1em; text-transform: uppercase; font-weight: 700; margin: 0 0 12px; }
  .hero h1 { font-family: "Playfair Display", Georgia, serif; font-size: clamp(28px, 5vw, 44px); font-weight: 600; line-height: 1.2; margin: 0 0 14px; color: var(--ink); }
  .hero-sub { color: var(--muted); font-size: 17px; margin: 0 0 24px; }
  .search-box { max-width: 480px; margin: 0 auto; }
  .search-box input { width: 100%; box-sizing: border-box; background: var(--surface); border: 1px solid var(--line); border-radius: 12px; padding: 13px 18px; font-size: 15px; color: var(--ink); outline: none; transition: border-color .2s; }
  .search-box input::placeholder { color: var(--faint); }
  .search-box input:focus { border-color: var(--gold); }
  .no-results { text-align: center; color: var(--muted); padding: 32px 0; font-size: 15px; }

  /* ── Region sections ──────────────────────────────────────────────────────── */
  .region-section { margin-bottom: 56px; }
  .region-title { font-family: "Playfair Display", serif; font-size: 22px; font-weight: 600; color: var(--gold); margin: 0 0 20px; padding-bottom: 10px; border-bottom: 1px solid var(--line); }

  /* ── City grid ────────────────────────────────────────────────────────────── */
  .city-grid { display: grid; gap: 16px; grid-template-columns: 1fr; }
  @media (min-width: 560px)  { .city-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px)  { .city-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1080px) { .city-grid { grid-template-columns: repeat(4, 1fr); } }

  /* ── City card ────────────────────────────────────────────────────────────── */
  .city-card { background: var(--surface); border: 1px solid var(--line); border-radius: 14px; padding: 16px; transition: border-color .2s; }
  .city-card:hover { border-color: color-mix(in srgb, var(--gold) 40%, transparent); }
  .city-header { margin-bottom: 12px; }
  .city-name { font-size: 15px; font-weight: 700; color: var(--ink); margin: 0 0 2px; }
  .city-country { font-size: 12px; color: var(--faint); margin: 0; }

  /* ── Season buttons ───────────────────────────────────────────────────────── */
  .season-row { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
  .season-btn { display: flex; align-items: center; gap: 5px; background: var(--bg); border: 1px solid var(--line); border-radius: 8px; padding: 7px 10px; text-decoration: none; font-size: 12px; color: var(--muted); transition: all .15s; white-space: nowrap; }
  .season-btn:hover { border-color: var(--gold); color: var(--gold); background: color-mix(in srgb, var(--gold) 8%, var(--bg)); }

  /* ── CTA ──────────────────────────────────────────────────────────────────── */
  .tool-cta { margin: 40px 0; padding: 32px; border-radius: 18px; border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent); background: linear-gradient(135deg, color-mix(in srgb, var(--gold) 12%, var(--surface)), var(--surface)); text-align: center; }
  .tool-cta h3 { font-family: "Playfair Display", serif; font-size: 22px; margin-bottom: 8px; }
  .tool-cta p { color: var(--muted); margin: 0 0 16px; }
  .btn { display: inline-block; background: var(--gold); color: var(--bg); font-weight: 600; text-decoration: none; padding: 13px 26px; border-radius: 12px; transition: background 0.2s; }
  .btn:hover { background: #d8b67e; }

  /* ── Footer ───────────────────────────────────────────────────────────────── */
  .site-footer { border-top: 1px solid rgba(58,48,38,.6); background: #1d1610; text-align: center; padding: 40px 20px; font-size: 12px; color: var(--faint); }
  .site-footer-logo { font-family: "Playfair Display", serif; font-size: 16px; color: var(--muted); margin: 0 0 12px; }
  .aiom { margin-top: 8px; }
  .aiom a { color: var(--gold); font-weight: 500; }
</style>
