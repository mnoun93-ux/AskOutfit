---
import Base from "../layouts/Base.astro";

const modules = import.meta.glob("../content/articles/*.json", { eager: true });
const all = Object.values(modules).map((m: any) => m.default ?? m);
const articles = all
  .filter((a: any) => a.lang === "en")
  .map((a: any) => ({
    slug: a.slug,
    h1: a.h1,
    title: a.title,
  }));

const SITE = "https://askoutfit.com";

// Occasion labels for tabs
const OCCASION_LABELS: Record<string, string> = {
  "wedding-guest":    "Weddings",
  "beach-party":      "Beach Party",
  "birthday-party":   "Birthday",
  "brunch":           "Brunch",
  "business-meeting": "Business",
  "casual-outing":    "Casual",
  "concert":          "Concerts",
  "dinner-party":     "Dinner",
  "eid-celebration":  "Eid",
  "engagement-party": "Engagement",
  "first-date":       "First Date",
  "graduation":       "Graduation",
  "job-interview":    "Interview",
  "office":           "Office",
  "travel-day":       "Travel",
};

// Embed data for client-side filtering
const articlesJson = JSON.stringify(articles);
---

<Base
  title="All Outfit Guides — Articles"
  description="Browse every Askoutfit style guide. Outfit ideas for weddings, interviews, dates, parties and more — filtered by occasion and gender."
  canonical={`${SITE}/articles/`}
  altLang="ar"
  altUrl={`${SITE}/articles-ar/`}
>
  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="site-logo">Askoutfit</a>
      <nav class="site-nav">
        <a href="/" class="site-nav-link">Home</a>
        <a href="/articles-ar/" class="site-lang">العربية</a>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <h1 class="page-title">All Outfit Guides</h1>
    <p class="page-sub">Pick an occasion — we'll show you exactly what to wear.</p>

    <!-- Search -->
    <div class="search-wrap">
      <input id="search" type="search" placeholder="Search guides…" autocomplete="off" />
    </div>

    <!-- Occasion tabs -->
    <div class="tabs-wrap" role="tablist" aria-label="Filter by occasion">
      <button class="tab active" data-occ="" role="tab" aria-selected="true">All</button>
      {Object.entries(OCCASION_LABELS).map(([key, label]) => (
        <button class="tab" data-occ={key} role="tab" aria-selected="false">{label}</button>
      ))}
    </div>

    <!-- Gender filter -->
    <div class="gender-wrap">
      <button class="pill active" data-gender="">Everyone</button>
      <button class="pill" data-gender="men">Men</button>
      <button class="pill" data-gender="women">Women</button>
    </div>

    <!-- Count -->
    <p class="count-line"><span id="count">{articles.length}</span> guides</p>

    <!-- Grid — rendered by JS -->
    <div class="art-grid" id="grid"></div>
    <p class="empty-msg" id="empty" style="display:none">No guides found for this filter. <button class="reset-btn" id="reset">Clear filters</button></p>
  </main>

  <footer class="site-footer">
    <p class="site-footer-logo">Askoutfit</p>
    <p>We may earn a commission on purchases through links. © <span id="y"></span></p>
    <p class="aiom">A project by <a href="https://www.aiom.ai/contact" target="_blank" rel="noopener">AIOM Automation Solutions</a></p>
  </footer>

  <script is:inline define:vars={{ articlesJson, OCCASION_LABELS }}>
    document.getElementById("y").textContent = new Date().getFullYear();

    const DATA = JSON.parse(articlesJson);
    let activeOcc = "";
    let activeGender = "";
    let searchQ = "";

    // ── slug helpers ────────────────────────────────────────────────────────
    const OCCS = Object.keys(OCCASION_LABELS);
    function occOf(slug)    { return OCCS.find(o => slug.includes(o)) || ""; }
    function genderOf(slug) {
      return slug.includes("-men") || slug.includes("for-men") ? "men"
           : slug.includes("-women") || slug.includes("for-women") ? "women"
           : "";
    }
    const OCCASION_EMOJIS = {
      "wedding-guest":"💍","beach-party":"🏖","birthday-party":"🎂","brunch":"☕",
      "business-meeting":"💼","casual-outing":"🛍","concert":"🎵","dinner-party":"🍽",
      "eid-celebration":"🌙","engagement-party":"💫","first-date":"✨",
      "graduation":"🎓","job-interview":"🎯","office":"🏢","travel-day":"✈️",
    };

    // ── render ───────────────────────────────────────────────────────────────
    const grid  = document.getElementById("grid");
    const empty = document.getElementById("empty");
    const count = document.getElementById("count");

    function render() {
      const q = searchQ.trim().toLowerCase();
      const filtered = DATA.filter(a => {
        if (activeOcc && occOf(a.slug) !== activeOcc) return false;
        if (activeGender && genderOf(a.slug) !== activeGender) return false;
        if (q && !a.h1.toLowerCase().includes(q) && !a.slug.includes(q)) return false;
        return true;
      });

      count.textContent = filtered.length;
      grid.innerHTML = filtered.map(a => {
        const occ = occOf(a.slug);
        const emoji = OCCASION_EMOJIS[occ] || "👗";
        const occLabel = OCCASION_LABELS[occ] || "";
        const gen = genderOf(a.slug);
        const genLabel = gen === "men" ? "Men" : gen === "women" ? "Women" : "";
        return `<a href="/${a.slug}/" class="art-card">
          <span class="art-card-emoji">${emoji}</span>
          <div class="art-card-body">
            ${occLabel ? `<span class="art-card-occ">${occLabel}${genLabel ? " · " + genLabel : ""}</span>` : ""}
            <p class="art-card-title">${a.h1}</p>
          </div>
          <span class="art-arrow">→</span>
        </a>`;
      }).join("");

      empty.style.display = filtered.length === 0 ? "block" : "none";
    }

    render();

    // ── URL param ?q= (Google SearchAction sitelinks) ────────────────────────
    const urlQ = new URLSearchParams(window.location.search).get("q");
    if (urlQ) {
      searchQ = urlQ;
      document.getElementById("search").value = urlQ;
      render();
    }

    // ── tabs ─────────────────────────────────────────────────────────────────
    document.querySelectorAll(".tab").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach(b => { b.classList.remove("active"); b.setAttribute("aria-selected","false"); });
        btn.classList.add("active");
        btn.setAttribute("aria-selected","true");
        activeOcc = btn.dataset.occ || "";
        render();
      });
    });

    // ── gender pills ─────────────────────────────────────────────────────────
    document.querySelectorAll(".pill").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".pill").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        activeGender = btn.dataset.gender || "";
        render();
      });
    });

    // ── search ───────────────────────────────────────────────────────────────
    let debounce;
    document.getElementById("search").addEventListener("input", e => {
      clearTimeout(debounce);
      debounce = setTimeout(() => { searchQ = e.target.value; render(); }, 180);
    });

    // ── reset ─────────────────────────────────────────────────────────────────
    document.getElementById("reset").addEventListener("click", () => {
      activeOcc = ""; activeGender = ""; searchQ = "";
      document.getElementById("search").value = "";
      document.querySelectorAll(".tab").forEach((b,i)  => { b.classList.toggle("active", i===0); b.setAttribute("aria-selected", i===0 ? "true":"false"); });
      document.querySelectorAll(".pill").forEach((b,i) => b.classList.toggle("active", i===0));
      render();
    });
  </script>
</Base>

<style>
  /* ── header ─────────────────────────────────────────────────────────────── */
  .site-header { position: sticky; top: 0; z-index: 20; border-bottom: 1px solid rgba(58,48,38,.6); background: rgba(26,20,16,.85); backdrop-filter: blur(12px); }
  .site-header-inner { max-width: 960px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; }
  .site-logo { font-family: "Playfair Display", Georgia, serif; font-size: 20px; font-weight: 600; text-decoration: none; color: var(--ink); }
  .site-nav { display: flex; align-items: center; gap: 16px; }
  .site-nav-link { font-size: 14px; color: var(--muted); text-decoration: none; }
  .site-nav-link:hover { color: var(--ink); }
  .site-lang { border: 1px solid var(--line); color: var(--muted); font-size: 12px; padding: 6px 12px; border-radius: 999px; text-decoration: none; }
  .site-lang:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); color: var(--ink); }

  /* ── layout ─────────────────────────────────────────────────────────────── */
  .wrap { max-width: 960px; margin: 0 auto; padding: 40px 20px 80px; }
  .page-title { font-family: "Playfair Display", Georgia, serif; font-weight: 600; font-size: clamp(30px, 5vw, 44px); margin: 0; color: var(--ink); }
  .page-sub { color: var(--muted); font-size: 17px; margin: 12px 0 28px; }

  /* ── search ─────────────────────────────────────────────────────────────── */
  .search-wrap { margin-bottom: 20px; }
  #search {
    width: 100%; max-width: 400px;
    background: var(--surface); border: 1px solid var(--line); border-radius: 10px;
    color: var(--ink); font-size: 15px; padding: 11px 16px;
    outline: none; transition: border-color .2s;
  }
  #search:focus { border-color: color-mix(in srgb, var(--gold) 60%, transparent); }
  #search::placeholder { color: var(--faint); }

  /* ── tabs ───────────────────────────────────────────────────────────────── */
  .tabs-wrap { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
  .tab {
    background: var(--surface); border: 1px solid var(--line); color: var(--muted);
    font-size: 13px; font-weight: 500; padding: 7px 14px; border-radius: 999px;
    cursor: pointer; transition: .15s; white-space: nowrap;
  }
  .tab:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); color: var(--ink); }
  .tab.active { background: var(--gold); border-color: var(--gold); color: var(--bg); font-weight: 600; }

  /* ── gender pills ───────────────────────────────────────────────────────── */
  .gender-wrap { display: flex; gap: 8px; margin-bottom: 20px; }
  .pill {
    background: transparent; border: 1px solid var(--line); color: var(--muted);
    font-size: 13px; padding: 5px 16px; border-radius: 999px;
    cursor: pointer; transition: .15s;
  }
  .pill:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); color: var(--ink); }
  .pill.active { border-color: var(--gold); color: var(--gold); font-weight: 600; }

  /* ── count ──────────────────────────────────────────────────────────────── */
  .count-line { font-size: 13px; color: var(--faint); margin-bottom: 20px; }

  /* ── grid ───────────────────────────────────────────────────────────────── */
  .art-grid { display: grid; gap: 12px; grid-template-columns: 1fr; }
  @media (min-width: 640px)  { .art-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .art-grid { grid-template-columns: repeat(3, 1fr); } }
  .art-card { display: flex; align-items: center; gap: 14px; border: 1px solid var(--line); background: var(--surface); padding: 16px 18px; border-radius: 14px; text-decoration: none; transition: .2s; }
  .art-card:hover { border-color: color-mix(in srgb, var(--gold) 50%, transparent); background: #271f17; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.2); }
  .art-card-emoji { font-size: 22px; flex-shrink: 0; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: rgba(202,164,106,.1); border-radius: 10px; }
  .art-card-body { flex: 1; min-width: 0; }
  .art-card-occ { display: block; font-size: 11px; color: var(--faint); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 4px; }
  .art-card-title { margin: 0; font-size: 14px; font-weight: 600; line-height: 1.4; color: var(--gold); }
  .art-card:hover .art-card-title { color: #d8b67e; }
  .art-arrow { color: var(--faint); flex-shrink: 0; font-size: 16px; transition: color .2s; }
  .art-card:hover .art-arrow { color: var(--gold); }

  /* ── empty state ────────────────────────────────────────────────────────── */
  .empty-msg { color: var(--muted); font-size: 15px; padding: 40px 0; text-align: center; }
  .reset-btn { background: none; border: 1px solid var(--line); color: var(--gold); font-size: 14px; padding: 6px 16px; border-radius: 8px; cursor: pointer; margin-left: 8px; }
  .reset-btn:hover { border-color: var(--gold); }

  /* ── footer ─────────────────────────────────────────────────────────────── */
  .site-footer { border-top: 1px solid rgba(58,48,38,.6); background: #1d1610; text-align: center; padding: 40px 20px; font-size: 12px; color: var(--faint); }
  .site-footer-logo { font-family: "Playfair Display", serif; font-size: 16px; color: var(--muted); margin: 0 0 12px; }
  .aiom { margin-top: 8px; }
  .aiom a { color: var(--gold); font-weight: 500; }
</style>
